{
  "multipart": [
    {
      "when": {
        "facing": "north",
        "inverted": "false"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body"
      }
    },
    {
      "when": {
        "facing": "north",
        "inverted": "true"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "x": 180,
        "y": 180
      }
    },
    {
      "when": {
        "facing": "east",
        "inverted": "false"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "y": 90
      }
    },
    {
      "when": {
        "facing": "east",
        "inverted": "true"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "x": 180,
        "y": 270
      }
    },
    {
      "when": {
        "facing": "south",
        "inverted": "false"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "y": 180
      }
    },
    {
      "when": {
        "facing": "south",
        "inverted": "true"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "x": 180
      }
    },
    {
      "when": {
        "facing": "west",
        "inverted": "false"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "y": 270
      }
    },
    {
      "when": {
        "facing": "west",
        "inverted": "true"
      },
      "apply": {
        "model": "full_steam_ahead:block/steam_admission_valve/body",
        "x": 180,
        "y": 90
      }
    },
    {
      "when": {
        "facing": "north",
        "east": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/east"
      }
    },
    {
      "when": {
        "facing": "north",
        "south": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/south"
      }
    },
    {
      "when": {
        "facing": "north",
        "west": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/west"
      }
    },
    {
      "when": {
        "facing": "east",
        "north": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/north"
      }
    },
    {
      "when": {
        "facing": "east",
        "south": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/south"
      }
    },
    {
      "when": {
        "facing": "east",
        "west": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/west"
      }
    },
    {
      "when": {
        "facing": "south",
        "north": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/north"
      }
    },
    {
      "when": {
        "facing": "south",
        "east": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/east"
      }
    },
    {
      "when": {
        "facing": "south",
        "west": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/west"
      }
    },
    {
      "when": {
        "facing": "west",
        "north": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/north"
      }
    },
    {
      "when": {
        "facing": "west",
        "east": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/east"
      }
    },
    {
      "when": {
        "facing": "west",
        "south": "true"
      },
      "apply": {
        "model": "create:block/fluid_pipe/connection/south"
      }
    }
  ]
}
