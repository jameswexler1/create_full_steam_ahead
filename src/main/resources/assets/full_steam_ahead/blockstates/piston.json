{
  "multipart": [
    {
      "when": {
        "assembled": "false",
        "axis": "x",
        "facing": "up"
      },
      "apply": {
        "model": "full_steam_ahead:block/piston",
        "y": 270
      }
    },
    {
      "when": {
        "assembled": "false",
        "axis": "z",
        "facing": "up"
      },
      "apply": {
        "model": "full_steam_ahead:block/piston"
      }
    },
    {
      "when": {
        "assembled": "false",
        "axis": "x",
        "facing": "down"
      },
      "apply": {
        "model": "full_steam_ahead:block/piston",
        "x": 180,
        "y": 270
      }
    },
    {
      "when": {
        "assembled": "false",
        "axis": "z",
        "facing": "down"
      },
      "apply": {
        "model": "full_steam_ahead:block/piston",
        "x": 180
      }
    }
  ]
}
