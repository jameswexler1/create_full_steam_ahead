{
  "multipart": [
    {
      "when": { "attached_face": "up", "facing": "north" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve" }
    },
    {
      "when": { "attached_face": "up", "facing": "east" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "y": 90 }
    },
    {
      "when": { "attached_face": "up", "facing": "south" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "y": 180 }
    },
    {
      "when": { "attached_face": "up", "facing": "west" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "y": 270 }
    },
    {
      "when": { "attached_face": "north" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "x": 90 }
    },
    {
      "when": { "attached_face": "east" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "x": 90, "y": 90 }
    },
    {
      "when": { "attached_face": "south" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "x": 90, "y": 180 }
    },
    {
      "when": { "attached_face": "west" },
      "apply": { "model": "full_steam_ahead:block/steam_relief_valve", "x": 90, "y": 270 }
    }
  ]
}
